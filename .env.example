# ============================================================
# Environment Variables — reference file (committed to git).
#
# Copy this to .env.local and fill in your values:
#   cp .env.example .env.local
#
# .env.local holds your real values and is gitignored — never commit it. The
# .gitignore rules live in .gitignore.hexagen; append them once with
# `cat .gitignore.hexagen >> .gitignore` (see SETUP.md).
#
# Mark a variable REQUIRED with a `# required` comment, e.g.:
#   API_KEY=          # required
# `npm run check:env` then fails until every required variable (here and in any
# .env.<template>.example file) has a value in .env.local. An empty value with
# no `# required` annotation is just an optional placeholder.
#
# Installed Hexagen templates ship their own variables in .env.<name>.example
# files (e.g. the bullmq template ships .env.bullmq.example); check:env scans
# all of them.
# ============================================================

# -------- App --------
# development | production | test
NODE_ENV=development
# Public base URL of the app (exposed to the browser).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# error | warn | info | debug
LOG_LEVEL=info

# -------- Image generation (optional) --------
# Google Gemini / Imagen API key. When set, hero backgrounds are generated with
# Google Imagen; otherwise the pipeline uses the offline procedural generator.
# Get a key at https://aistudio.google.com/apikey — put the real value in .env.local
GEMINI_API_KEY=
# Override the Imagen model (default: imagen-4.0-generate-001; "fast"/"ultra" variants exist).
# IMAGEN_MODEL=imagen-4.0-fast-generate-001
